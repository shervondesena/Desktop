<!-- Dung cho viec nguoi dung vao trang auth/register thi phai hide di reg modal -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const currentPath = window.location.pathname;
    if (currentPath === '/auth/register') {
      // Xóa các phần tử có class modal-register
      const elementsToRemoveByClass = document.querySelectorAll('.modal-register');
      elementsToRemoveByClass.forEach(element => {
        element.remove();
      });

      // Xóa phần tử có id reg
      const elementToRemoveById = document.getElementById('reg');
      if (elementToRemoveById) {
        elementToRemoveById.remove();
      }
    }
  });
</script>

