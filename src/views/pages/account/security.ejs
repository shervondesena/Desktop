            display: inline-block;
            width: 26%;
            vertical-align: top;
            margin: 10px 3%;
            background: hsla(0, 0%, 80%, .6);
            border-radius: 5px;
            cursor: pointer;
        }

        ._1v_g9pbVFecDdUM3Df4Cdk li button {
            width: 100%;
            min-height: 150px;
            padding: 25px 0 15px;
