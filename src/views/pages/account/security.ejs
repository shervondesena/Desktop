            font-size: 14px;
            border: 1px solid #b9b6b6;
            border-radius: 5px;
        }

        .button-passwd button {
            padding: 5px 30px;
            cursor: pointer;
            width: 20%;
        }

        .button-passwd div {
            text-align: center;
        }

        .button-passwd div button:nth-child(1) {
            background: linear-gradient(to top, #a80303, #ff0d00, #ffa008);
            border: none;
            outline: none;
            color: white;
            text-transform: uppercase;
        }

        .button-passwd div button:nth-child(2) {
            background: linear-gradient(to top, #b15a16, #f8d78a, #f8eab3);
            border: none;
            outline: none;
            color: black;
