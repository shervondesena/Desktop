        }

        .btn-link,
        .btn-link:hover,
        .btn-link:focus,
        .btn-link:active {
            border-color: transparent;
        }

        .btn-link,
        .btn-link:active,
        .btn-link.active,
        .btn-link[disabled],
        fieldset[disabled] .btn-link {
            background-color: transparent;
            box-shadow: none;
        }

        #form-changepwd {
            margin-top: 1rem;
        }

        .form-password-1 {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
            justify-content: center;
        }

        .form-password-1 div {
            width: 50%;
