    <!-- Modal Lucky -->
    <script>

        $.ajax({
            url: "<%=dataPage.config.MAIN_API%>/api/luckymoney/check",
            method: "GET",
            timeout: 0,
            headers: {
                "Authorization": "Bearer <%=dataPage.session.accessToken%>",
                "Content-Type": "application/x-www-form-urlencoded"
            },
            success: function (response) {
                // Nếu kết quả trả về status là true, hiển thị modal và set amount
                if (response.status === true) {
                    // Set số tiền vào phần tử có id là "set_amount_of_lucky"
                    document.getElementById("set_amount_of_lucky").textContent = parseInt(response.amount / 1000).toLocaleString('vi-VN');

                    // Hiển thị modalLucky bằng flex
                    document.querySelector('.modalLucky').style.display = 'flex';
                } else {
                    console.log("Không đủ điều kiện nhận Lucky Money");
                }
            },
            error: function (xhr, status, error) {
                console.error("Đã xảy ra lỗi: ", error);
            }
        });

        // Xử lý sự kiện click trên modalLucky để mở/đóng các phần tử
        document.querySelector('.modalLucky').addEventListener('click', function () {
            const itemClose = document.querySelector('.item-close');
            const itemOpen = document.querySelector('.item-open');
            const modal = document.querySelector('.modalLucky');

            if (itemClose.style.display !== 'none') {
                // Nếu item-close đang hiển thị, ẩn nó và hiện item-open
                itemClose.style.display = 'none';
                itemOpen.style.display = 'block';
                // Gui api xac nhan lay bao li xi
                $.ajax({
                    url: "<%=dataPage.config.MAIN_API%>/api/luckymoney/confirmGet",
                    method: "GET",
                    timeout: 0,
                    headers: {
                        "Authorization": "Bearer <%=dataPage.session.accessToken%>",
                        "Content-Type": "application/x-www-form-urlencoded"
                    },
                    success: function (response) {
                        if (response.status === true) {
                            
                        } else {
                            alert("Không thể nhận lì xì: " + response.msg);
                            modal.style.display = 'none';
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Đã xảy ra lỗi: ", error);
                    }
                });
            } else {
                // Nếu item-open đang hiển thị, ẩn toàn bộ modal
                modal.style.display = 'none';
                location.reload();
            }
        });
    </script>

