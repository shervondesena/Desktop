    <style>
        /* Animation for sliding down */
        @keyframes slideDown {
            0% {
                transform: translateY(-100%);
                opacity: 0;
            }

            100% {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* Modal container */
        .modalLucky {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100vh;
            display: none;
            justify-content: center;
            align-items: center;
            background-color: rgba(0, 0, 0, 0.6);
            z-index: 9999 !important;
        }

        /* Modal content */
        .modal-content-lucky {
            height: 707px;
            width: 100%;
            padding: 20px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
            border-radius: 10px;
            animation: slideDown 0.5s ease-out;
        }

        .modal-content-lucky .item {
            background: linear-gradient(to bottom, #fc0 70%, rgba(255, 204, 0, 0) 100%);
            position: relative;
            height: 350px;
            top: 60%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 300px;
            text-align: center;
            border-radius: 10px;
            padding: 1rem
        }

        .modal-content-lucky .item img {
            cursor: pointer;
        }

        .modal-content-lucky .item .item-header {
            padding: 0 2rem;
            margin-bottom: 1rem;
        }

        .modal-content-lucky .item .item-header p {
            background: black;
            border-radius: 5px;
            padding: 10px;
            color: white;
        }

        @keyframes pulse {
            0% {
                transform: scale(1);
            }

            50% {
                transform: scale(1.1);
            }

            100% {
                transform: scale(1);
            }
        }

        @keyframes flyUp {
            0% {
                transform: translateY(150px);
                opacity: 0;
            }

            50% {
                transform: translateY(70px);
                opacity: 0.5;
            }

            100% {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .luckymoney {
            animation: pulse 1s infinite;
        }

        .moneyopen {
            animation: flyUp 1s linear;
        }
    </style>
